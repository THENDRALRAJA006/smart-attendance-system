# ============================================================
# SmartAttend — Environment Configuration Template
# Copy this to .env and fill in your values
# ============================================================

# ─── App ─────────────────────────────────────────────────────
APP_NAME=SmartAttend
APP_ENV=development
APP_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRE_DAYS=7

# ─── MySQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_attendance

# ─── AWS ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-s3-bucket-name
S3_FACE_PREFIX=faces
AWS_REKOGNITION_COLLECTION_ID=smart-attendance-faces

# ─── Face Verification ────────────────────────────────────────
FACE_CONFIDENCE_THRESHOLD=90.0
