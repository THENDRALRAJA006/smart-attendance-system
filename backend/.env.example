# ============================================================
# SmartAttend — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================
# cp .env.example .env

# ─── App ─────────────────────────────────────────────────────
APP_NAME=SmartAttend
APP_ENV=development                   # development | production
APP_BASE_URL=http://localhost:8000    # Change to Render URL in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_SECRET_KEY=CHANGE_ME_GENERATE_DIFFERENT_SECRET
JWT_REFRESH_EXPIRE_DAYS=7

# ─── MySQL Database (AWS RDS) ─────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=smart_attendance

# ─── AWS Services ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_FACE_PREFIX=faces
AWS_REKOGNITION_COLLECTION_ID=smart-attendance-faces

# ─── Face Verification ────────────────────────────────────────
FACE_CONFIDENCE_THRESHOLD=90.0
