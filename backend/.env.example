# ============================================================
# SmartAttend — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================
# cp .env.example .env

# ─── App ─────────────────────────────────────────────────────
APP_NAME=SmartAttend
APP_ENV=development                   # development | production
APP_BASE_URL=http://localhost:8000    # Change to Render URL in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_SECRET_KEY=CHANGE_ME_GENERATE_DIFFERENT_SECRET
JWT_REFRESH_EXPIRE_DAYS=7

# ─── MySQL Database (RDS) ────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=smart_attendance

# ─── ArcFace (InsightFace) ───────────────────────────────────
# Cosine similarity thresholds (0.0–1.0 scale, NOT percentages)
ARCFACE_SIMILARITY_THRESHOLD=0.75   # >= 0.75 → present
ARCFACE_REVIEW_THRESHOLD=0.65       # 0.65–0.74 → manual_review; < 0.65 → rejected
ARCFACE_MODEL_PATH=~/.insightface   # InsightFace model cache directory
